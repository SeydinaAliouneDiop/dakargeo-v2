# ──────────────────────────────────────────────────────
# DakarGeo v2 — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ──────────────────────────────────────────────────────

# OPTION 1 (recommandée) : URL complète Supabase
# Aller sur supabase.com → ton projet → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[MOT_DE_PASSE]@db.[TON_ID].supabase.co:5432/postgres

# OPTION 2 : Variables séparées (si tu n'utilises pas DATABASE_URL)
# DB_HOST=db.[TON_ID].supabase.co
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=ton_mot_de_passe

# Port du serveur Express (Render le définit automatiquement)
PORT=3000
